# Environment Variables Template
# Copy this file to .env and fill in the actual values.
# NEVER commit the .env file to version control.

# Firebase Configuration
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Note: Google Apps Script is no longer required.
# The blood centre finder (public/bloodcenter.html) now queries registered
# blood banks directly from Firestore.  Copy the same Firebase values into
# public/firebase-config.js to enable live lookups on that page.
