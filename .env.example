# Environment Variables Template
# Copy this file to .env and fill in the actual values.
# NEVER commit the .env file to version control.

# Firebase Configuration
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Google Apps Script API URL
VITE_API_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# Admin Registration Key (comma-separated list of valid keys)
# Keep this secret — only share with trusted administrators
VITE_ADMIN_REGISTRATION_KEYS=your_admin_key_here
